# ── Backend local dev environment ────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# ── Local SQL Server (or Azure SQL) ───────────────────────────
# Option A: full connection string (takes priority)
# SQL_CONNECTION_STRING=Server=localhost;Database=appdb;User ID=sa;Password=YourPassword;Encrypt=False;

# Option B: individual fields
SQL_SERVER=localhost
SQL_DATABASE=appdb
SQL_USER=sa
SQL_PASSWORD=YourStrong@Passw0rd
SQL_PORT=1433

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=local-dev-secret-change-in-production-32chars

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ── App Insights (leave blank for local dev) ──────────────────
# APPLICATIONINSIGHTS_CONNECTION_STRING=
