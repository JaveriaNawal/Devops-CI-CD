# Terraform state — never commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform variable files with secrets — never commit
*.tfvars
*.tfvars.json
!terraform.tfvars.example

# Terraform working directories
.terraform/
.terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Terraform plan output
*.tfplan
