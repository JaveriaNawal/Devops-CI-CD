# ── Frontend local dev environment ───────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.

# ── API Base URL ──────────────────────────────────────────────
# Leave blank for local dev — Vite proxies /api → localhost:8080
# Set to your backend URL for staging/production builds
# VITE_API_BASE_URL=https://myapp-staging.azurewebsites.net/api
